# Server Configuration
# PORT: The port the server will run on (e.g., 3000)
PORT=3000
# NODE_ENV: Should be 'production' when deployed live
NODE_ENV=development
# LOG_LEVEL: Control logging output ('info', 'debug', 'error')
LOG_LEVEL=info

# CORS Configuration
# FRONTEND_URL: The exact URL of the deployed frontend (e.g., https://myportfolio.com)
FRONTEND_URL="http://localhost:3000"

# Database Configuration (Neon PostgreSQL)
# DATABASE_URL: Your production PostgreSQL connection string
DATABASE_URL="postgresql://user:password@hostname/dbname?sslmode=require"

# Auth Configuration
# JWT_SECRET: A strong, random string used to sign JWT tokens. MUST be set in production.
JWT_SECRET="super-secret-key-change-me-in-production"
# JWT_EXPIRES_IN: Token validity duration (e.g., '24h', '7d')
JWT_EXPIRES_IN="24h"

# Resume Configuration
# RESUME_URL: Optional fallback URL for your resume
RESUME_URL="https://example.com/path-to-your-resume.pdf"

# Initial Admin Password (used by seed-admin.ts)
# ADMIN_INITIAL_PASSWORD: Password to seed the admin account initially. Should be removed/rotated after initial setup.
ADMIN_INITIAL_PASSWORD="password123"
